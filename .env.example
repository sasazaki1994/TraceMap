DATABASE_URL="postgresql://tracemap:tracemap@localhost:5432/tracemap?schema=public"

# Answer graph provider: mock (default) | stub | openai
# TRACEMAP_ANSWER_GRAPH_PROVIDER=mock

# OpenAI (only when TRACEMAP_ANSWER_GRAPH_PROVIDER=openai)
# TRACEMAP_OPENAI_API_KEY=
# Optional: fallback name used by many tools if TRACEMAP_OPENAI_API_KEY is unset
# OPENAI_API_KEY=
# TRACEMAP_OPENAI_MODEL=gpt-4o-mini
# TRACEMAP_OPENAI_TIMEOUT_MS=60000
