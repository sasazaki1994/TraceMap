generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AnalysisRunStatus {
  queued
  processing
  completed
  failed
}

enum SourceSnapshotType {
  web
  document
  note
}

enum AlertLevel {
  info
  warning
  error
}

enum SourceVerificationStatus {
  verified
  unverified
  unreachable
  invalid
}

enum ClaimSupportKind {
  direct
  supplemental
  indirect
}

enum ClaimConfidenceLevel {
  high
  medium
  low
  insufficient
}

enum ClaimRecencyStatus {
  current
  stale
  unknown
}

model AnalysisRun {
  id                String            @id @default(cuid())
  question          String
  status            AnalysisRunStatus @default(queued)
  lastErrorMessage  String?           @map("last_error_message")
  answerSnapshots   AnswerSnapshot[]
  sourceSnapshots SourceSnapshot[]
  shareLinks      ShareLink[]
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  @@map("analysis_runs")
}

model AnswerSnapshot {
  id              String           @id @default(cuid())
  analysisRunId   String           @map("analysis_run_id")
  title           String?
  content         String
  model           String?
  graphJson       Json?            @map("graph_json")
  sourceSnapshots SourceSnapshot[]
  claims          Claim[]
  alerts          Alert[]
  createdAt       DateTime         @default(now()) @map("created_at")
  analysisRun     AnalysisRun      @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)

  @@index([analysisRunId])
  @@map("answer_snapshots")
}

model SourceSnapshot {
  id                   String                   @id @default(cuid())
  analysisRunId        String                   @map("analysis_run_id")
  answerSnapshotId     String?                  @map("answer_snapshot_id")
  label                String
  sourceType           SourceSnapshotType       @default(web) @map("source_type")
  url                  String?
  excerpt              String?
  publishedAt          DateTime?                @map("published_at")
  verificationStatus   SourceVerificationStatus @default(unverified) @map("verification_status")
  checkedAt            DateTime?                @map("checked_at")
  httpStatus           Int?                     @map("http_status")
  finalUrl             String?                  @map("final_url")
  contentType          String?                  @map("content_type")
  createdAt            DateTime                 @default(now()) @map("created_at")
  analysisRun          AnalysisRun              @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
  answerSnapshot       AnswerSnapshot?          @relation(fields: [answerSnapshotId], references: [id], onDelete: SetNull)
  claimSourceSnapshots ClaimSourceSnapshot[]

  @@index([analysisRunId])
  @@index([answerSnapshotId])
  @@map("source_snapshots")
}

model ShareLink {
  id            String      @id @default(cuid())
  analysisRunId String      @map("analysis_run_id")
  token         String      @unique
  expiresAt     DateTime?   @map("expires_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  analysisRun   AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)

  @@index([analysisRunId])
  @@map("share_links")
}

model Claim {
  id                   String                @id @default(cuid())
  answerSnapshotId     String                @map("answer_snapshot_id")
  summary              String
  graphNodeId          String?               @map("graph_node_id")
  createdAt            DateTime              @default(now()) @map("created_at")
  answerSnapshot       AnswerSnapshot        @relation(fields: [answerSnapshotId], references: [id], onDelete: Cascade)
  counterpoints        Counterpoint[]
  claimSourceSnapshots ClaimSourceSnapshot[]
  confidence           ClaimConfidence?
  alerts               Alert[]

  @@index([answerSnapshotId])
  @@map("claims")
}

model ClaimSourceSnapshot {
  id                String           @id @default(cuid())
  claimId           String           @map("claim_id")
  sourceSnapshotId  String           @map("source_snapshot_id")
  supportKind       ClaimSupportKind @default(direct) @map("support_kind")
  isPrimarySource   Boolean          @default(false) @map("is_primary_source")
  supportingQuote   String?          @map("supporting_quote")
  contradictionNote String?          @map("contradiction_note")
  createdAt         DateTime         @default(now()) @map("created_at")
  claim             Claim            @relation(fields: [claimId], references: [id], onDelete: Cascade)
  sourceSnapshot    SourceSnapshot   @relation(fields: [sourceSnapshotId], references: [id], onDelete: Cascade)

  @@unique([claimId, sourceSnapshotId])
  @@index([sourceSnapshotId])
  @@map("claim_source_snapshots")
}

model ClaimConfidence {
  id                     String               @id @default(cuid())
  claimId                String               @unique @map("claim_id")
  score                  Int
  level                  ClaimConfidenceLevel
  summary                String
  hasPrimarySource       Boolean              @default(false) @map("has_primary_source")
  independentSourceCount Int                  @default(0) @map("independent_source_count")
  hasSupportingQuote     Boolean              @default(false) @map("has_supporting_quote")
  recencyStatus          ClaimRecencyStatus   @default(unknown) @map("recency_status")
  hasContradiction       Boolean              @default(false) @map("has_contradiction")
  createdAt              DateTime             @default(now()) @map("created_at")
  claim                  Claim                @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@map("claim_confidences")
}

model Counterpoint {
  id        String   @id @default(cuid())
  claimId   String   @map("claim_id")
  summary   String
  createdAt DateTime @default(now()) @map("created_at")
  claim     Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId])
  @@map("counterpoints")
}

model Alert {
  id               String         @id @default(cuid())
  answerSnapshotId String         @map("answer_snapshot_id")
  claimId          String?        @map("claim_id")
  level            AlertLevel
  message          String
  createdAt        DateTime       @default(now()) @map("created_at")
  answerSnapshot   AnswerSnapshot @relation(fields: [answerSnapshotId], references: [id], onDelete: Cascade)
  claim            Claim?         @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([answerSnapshotId])
  @@index([claimId])
  @@map("alerts")
}
